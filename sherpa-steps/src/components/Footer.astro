---
const year = new Date().getFullYear();
---

<footer class="relative z-40 w-full bg-primary text-on-dark">
  <div class="grid grid-cols-1 gap-6 px-4 py-12 md:grid-cols-4 md:px-16">
    <div>
      <div class="font-display text-2xl font-bold uppercase text-white">Sherpa Steps</div>
      <p class="mt-4 text-sm text-on-dark/70">
        High-altitude training laboratory in Houston, TX, dedicated to mountaineering excellence.
        Est. 2019.
      </p>
    </div>
    <div class="flex flex-col gap-2">
      <span class="label-caps mb-2 text-accent-hi">Program</span>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="/program">12-Week Program</a>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="/altitude-room">Altitude Room</a>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="/summit-wall">Summit Wall</a>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="/leaderboard">Leaderboard</a>
      <a class="text-sm font-semibold text-accent-hi transition hover:text-white" href="/enroll">Enroll →</a>
    </div>
    <div class="flex flex-col gap-2">
      <span class="label-caps mb-2 text-accent-hi">Connect</span>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="#">@sherpasteps.houston</a>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="#">@summitwall</a>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="/coaches">Coaches &amp; Method</a>
      <a class="text-sm text-on-dark/75 transition hover:text-accent-hi" href="/faq">FAQ &amp; Logistics</a>
    </div>
    <div class="flex flex-col gap-2">
      <span class="label-caps mb-2 text-accent-hi">Houston, TX</span>
      <p class="text-sm text-on-dark/75">
        Mon–Fri 5:30am–9pm<br />Sat 7am–2pm<br />Closed Sunday
      </p>
    </div>
  </div>
  <div
    class="flex flex-col items-center justify-between gap-2 border-t border-white/10 px-4 py-6 text-[12px] text-on-dark/50 md:flex-row md:px-16"
  >
    <span>© {year} Sherpa Steps Trek Training. Houston, TX.</span>
    <div class="flex gap-6">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </div>
</footer>
